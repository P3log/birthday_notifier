# !/bin/bash

# Configures the files into the repository
database="dates.csv"
# set executables
files=(ajoute calcAge cherche dailyCheck launcher main)

for file in ${files[@]}; do
    chmod 777 ${file}
done

# set default path in the env file
if [ ! -f "env" ]; then
    touch env
fi
pwd > env


# create database if it does not exist
if [ ! -f "$database" ]; then
    touch dates.csv
    echo "#Prenom;Nom;jj/mm/aaaa > $database"
fi

exit 0
